# Resend API key (get one at https://resend.com/api-keys)
# Without this, the server will still accept requests but won't send emails.
RESEND_API_KEY=re_xxxxxxxxxxxx

# Optional: use your own verified domain for "from" address (default: onboarding@resend.dev)
# RESEND_FROM=Atheleta <orders@yourdomain.com>

# Optional: server port (default: 3001)
# PORT=3001
